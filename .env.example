# Настройки базы данных PostgreSQL
DB_USER=postgres
DB_PASS=postgres
DB_HOST=db
DB_PORT=5432
DB_NAME=url_shortener

# Настройки Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Секрет для JWT-токенов (сгенерировать: python -c "import secrets; print(secrets.token_hex(32))")
SECRET=your_secret_key_here

# Базовый URL сервиса (для генерации коротких ссылок)
BASE_URL=http://localhost:8000
